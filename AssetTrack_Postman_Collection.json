      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/dashboard",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN" }
            ]
          }
        }
      ]
